        '<span class="line"><span style="color:#737994;font-style:italic"># 加载模型</span></span>\n' +
        '<span class="line"><span style="color:#C6D0F5">model</span><span style="color:#949CBB">,</span><span style="color:#C6D0F5"> tokenizer </span><span style="color:#81C8BE">=</span><span style="color:#C6D0F5"> FastLanguageModel</span><span style="color:#949CBB">.</span><span style="color:#8CAAEE">from_pretrained</span><span style="color:#949CBB">(</span></span>\n' +
