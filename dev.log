        '<span class="line"><span style="color:#C6D0F5">run </span><span style="color:#81C8BE">=</span><span style="color:#C6D0F5"> wandb</span><span style="color:#949CBB">.</span><span style="color:#8CAAEE">init</span><span style="color:#949CBB">(</span><span style="color:#EA999C;font-style:italic">project</span><span style="color:#81C8BE">=</span><span style="color:#A6D189">"deepseek-fine-tune"</span><span style="color:#949CBB">,</span><span style="color:#EA999C;font-style:italic"> job_type</span><span style="color:#81C8BE">=</span><span style="color:#A6D189">"training"</span><span style="color:#949CBB">)</span></span></code></pre>\n' +
