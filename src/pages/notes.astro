---
import { getCollection, render } from "astro:content";
import LayoutBase from "../layouts/Base.astro";
import FormattedDate from "../components/FormattedDate.astro";

const notes = await getCollection("note");
const allNotesByDate = await Promise.all(
  notes
    .sort(
      (a, b) =>
        new Date(b.data.publishDate).getTime() -
        new Date(a.data.publishDate).getTime()
    )
    .map(async (note) => {
      const { Content } = await render(note);
      // 获取纯文本内容用于预览
      const body = note.body || '';
      const contentText = body
        .replace(/^---[\s\S]*?---/, '')
        .replace(/[#*`\[\]]/g, '')
        .replace(/\n+/g, ' ')
        .trim();
      
      return {
        ...note,
        preview: contentText.substring(0, 120) + (contentText.length > 120 ? '...' : ''),
        contentText
      };
    })
);
---

<LayoutBase>
  <section>
    <div class="mb-8">
      <h1 class="title text-2xl md:text-3xl mb-2">Notes</h1>
      <p class="text-lighter">
        {allNotesByDate.length > 0 
          ? `共 ${allNotesByDate.length} 篇笔记`
          : "暂无笔记"
        }
      </p>
    </div>

    {
      allNotesByDate.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {allNotesByDate.map((note) => (
            <div class="group">
              <article class="h-full flex flex-col rounded-lg bg-color-75 px-4 md:px-6 py-4 transition-all duration-200 hover:shadow-lg hover:bg-color-100 border border-color-50">
                <div class="flex-grow">
                  <h3 class="text-lg font-semibold mb-2 leading-tight">
                    <a href={`/verblog/notes/${note.slug}/`} class="citrus-link hover:text-accent-one transition-colors">
                      {note.data.title}
                    </a>
                  </h3>
                  
                  <div class="flex items-center text-sm text-lighter mb-3">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <FormattedDate
                      date={note.data.publishDate}
                      dateTimeOptions={{
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      }}
                    />
                  </div>
                  
                {(note.data.description || note.preview) && (
                  <p class="text-sm text-lighter leading-relaxed line-clamp-3">
                    {note.data.description || note.preview}
                  </p>
                )}                </div>
                
                <div class="mt-4 pt-3 border-t border-color-50/50">
                  <a href={`/verblog/notes/${note.slug}/`} class="text-sm font-medium text-accent-one hover:text-accent-two transition-colors flex items-center">
                    阅读全文
                    <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="text-6xl mb-4">📝</div>
          <h3 class="text-xl font-medium text-lighter mb-2">暂无笔记</h3>
          <p class="text-lighter">开始创建你的第一篇笔记吧！</p>
        </div>
      )
    }
  </section>
</LayoutBase>
